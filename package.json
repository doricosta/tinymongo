{
  "name": "tinymongo",
  "version": "0.1.0",
  "description": "Serverless MongoDB. One file. Zero configuration.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mongodb",
    "database",
    "embedded",
    "serverless"
  ],
  "license": "MIT",
  "peerDependencies": {
    "mongodb": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "mongodb": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "mongodb": "^7.4.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
